{
  "manifest_version": 3,
  "name": "Taobao Context Extractor",
  "version": "0.1.0",
  "description": "Extracts item detail data from rendered pages and downloads converted target JSON.",
  "permissions": [
    "downloads",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://item.taobao.com/*",
        "*://*.taobao.com/*",
        "*://*.tmall.com/*"
      ],
      "js": [
        "page_interceptor.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Taobao Context Extractor"
  }
}
