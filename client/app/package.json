{
  "name": "maserati",
  "version": "1.0.1",
  "description": "maserati Client Application",
  "main": "dist/main.js",
  "scripts": {
    "dev-mac": "export NODE_OPTIONS='--max-old-space-size=4096' && sh mac/dev.sh",
    "stop-mac": "sh mac/stop.sh",
    "dev-win": "set NODE_OPTIONS=--max-old-space-size=4096 && .\\win\\dev.bat",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 webpack --config webpack.config.js --mode production",
    "start": "electron . --disable-gpu --no-sandbox --max-old-space-size=4096",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron . --disable-gpu --no-sandbox --max-old-space-size=4096\"",
    "package:mac": "sh mac/package_mac.sh all",
    "package:mac:x86": "sh mac/package_mac.sh x86",
    "package:mac:x64": "sh mac/package_mac.sh x64",
    "package:mac:arm": "sh mac/package_mac.sh arm",
    "package:mac:arm64": "sh mac/package_mac.sh arm64",
    "package:win": "sh mac/package_win.sh all",
    "package:win:x86": "sh mac/package_win.sh x86",
    "package:win:x64": "sh mac/package_win.sh x64",
    "package:win:arm": "sh mac/package_win.sh arm",
    "package:win:arm64": "sh mac/package_win.sh arm64",
    "package:all": "npm run package:mac && npm run package:win",
    "package:win-by-win": ".\\win\\package_win.bat"
  },
  "build": {
    "appId": "com.x.ds.maserati.desk.app",
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "static/html",
        "to": "resource/html",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/sharp/**",
      "**/node_modules/@img/**"
    ],
    "directories": {
      "output": "package"
    },
    "productName": "maserati",
    "npmRebuild": false,
    "beforeBuild": "./scripts/rebuild-native.js",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "static/logo/logo.jpg",
      "category": "com.x.ds.maserati.category.type"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "static/logo/logo.jpg"
    },
    "publish": [
      {
        "provider": "generic",
        "url": ""
      }
    ],
    "releaseInfo": {
      "releaseNotes": ""
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "uninstallDisplayName": "${productName}",
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh"
    }
  },
  "_moduleAliases": {
    "@src": "dist/app/src",
    "@model": "dist/common/model",
    "@api": "dist/common/api",
    "@utils": "dist/common/utils",
    "@eleapi": "dist/common/eleapi"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@hono/node-server": "^1.13.7",
    "@types/semver": "^7.5.8",
    "adm-zip": "^0.5.14",
    "asynckit": "^0.4.0",
    "axios": "^1.7.2",
    "builder-util-runtime": "^9.2.10",
    "cheerio": "^1.0.0",
    "class-transformer": "^0.5.1",
    "combined-stream": "^1.0.8",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "crypto": "1.0.1",
    "debug": "^4.4.0",
    "detect-libc": "^2.0.3",
    "dotenv": "^16.4.5",
    "electron-log": "^5.2.4",
    "electron-updater": "^5.3.0",
    "express": "^5.1.0",
    "extract-zip": "^2.0.1",
    "follow-redirects": "^1.15.9",
    "form-data": "^4.0.1",
    "fs-extra": "^11.2.0",
    "graceful-fs": "^4.2.11",
    "hono": "^4.6.13",
    "https-proxy-agent": "^7.0.6",
    "js-yaml": "^4.1.0",
    "jsonfile": "^6.1.0",
    "lazy-val": "^1.0.5",
    "link-preview-js": "^3.2.0",
    "localforage": "^1.10.0",
    "lodash.escaperegexp": "^4.1.2",
    "lodash.isequal": "^4.5.0",
    "mime-db": "^1.53.0",
    "mime-types": "^2.1.35",
    "module-alias": "^2.2.3",
    "ms": "^2.1.3",
    "node-machine-id": "^1.1.12",
    "pino": "^9.5.0",
    "platform-specific": "^1.1.0",
    "playwright": "^1.58.2",
    "proxy-from-env": "^1.1.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "sax": "^1.4.1",
    "semver": "^7.6.3",
    "sharp": "^0.33.5",
    "sql.js": "^1.14.0",
    "typed-emitter": "^2.1.0",
    "universalify": "^2.0.1",
    "url": "^0.11.3",
    "uuid": "^11.0.3",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/axios": "^0.14.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/node": "^20.14.5",
    "@types/qrcode": "^1.5.6",
    "@types/reflect-metadata": "^0.0.5",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "electron": "^31.7.6",
    "electron-builder": "^24.13.3",
    "file-loader": "^6.2.0",
    "node-loader": "^2.1.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.5.3",
    "wait-on": "^7.2.0",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0",
    "webpack-node-externals": "^3.0.0"
  }
}
